---
import type { CollectionEntry } from "astro:content";
import Tag from "./Tag.astro";

export interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const formattedDate = post.data.date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
});
---

<a
    href={`/blog/${post.id}`}
    class="block bg-surface-container p-6 hover:bg-surface-container-high transition-colors group"
>
    <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
            <span
                class="font-mono text-label-sm text-primary uppercase tracking-wider"
            >
                {formattedDate}
            </span>

            {
                post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                        {post.data.tags.slice(0, 2).map((tag: string) => (
                            <Tag tag={tag} size="sm" />
                        ))}
                    </div>
                )
            }
        </div>

        <h3
            class="font-headline text-headline-sm font-semibold group-hover:text-primary transition-colors"
        >
            {post.data.title}
        </h3>

        <p class="font-body text-body-md text-onbackground/60 line-clamp-2">
            {post.data.description}
        </p>

        <div
            class="flex items-center gap-2 text-primary font-mono text-label-sm uppercase tracking-wider group-hover:translate-x-1 transition-transform"
        >
            <span>Read more</span>
            <span>&rarr;</span>
        </div>
    </div>
</a>

<style>
    html.light a {
        background-color: var(--color-surface-container);
    }

    html.light a:hover {
        background-color: var(--color-surface-container-high);
    }

    html.light .text-primary {
        color: var(--color-primary);
    }

    html.light .text-onbackground\/60 {
        color: var(--color-on-surface-variant);
    }

    html.light .group-hover\:text-primary:hover {
        color: var(--color-primary);
    }

    html.light .group-hover\:translate-x-1:hover {
        transform: translateX(4px);
    }
</style>
