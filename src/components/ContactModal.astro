---
export interface Props {
  isOpen: boolean;
}

const { isOpen } = Astro.props;
---

<dialog
  id="contact-modal"
  class="bg-surface light:bg-light-surface backdrop:bg-black/60 open:animate-fade-in fixed inset-0 z-50 w-full max-w-lg mx-auto my-auto p-6 rounded-lg border border-outline/30 light:border-light-outline/30 shadow-xl"
  style={isOpen ? { position: 'fixed', inset: 0, display: 'flex', alignItems: 'center', justifyContent: 'center' } : {}}
>
  <div class="w-full">
    <div class="flex justify-between items-center mb-6">
      <h2 class="font-headline text-2xl font-semibold text-on-surface light:text-light-on-surface">
        CONTACT_ME
      </h2>
      <button
        id="close-modal"
        type="button"
        class="font-mono text-sm text-on-surface-variant light:text-light-on-surface-variant hover:text-primary light:hover:text-light-primary transition-colors"
      >
        [ ESC ]
      </button>
    </div>

    <form id="contact-form" class="space-y-4">
      <div>
        <label for="name" class="font-mono text-xs text-primary light:text-light-primary uppercase tracking-wider block mb-2">
          NAME
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full bg-surface-container light:bg-light-surface-container border border-outline/30 light:border-light-outline/30 rounded px-4 py-3 font-body text-on-surface light:text-light-on-surface placeholder:text-on-surface-variant/40 light:placeholder:text-light-on-surface-variant/40 focus:outline-none focus:border-primary light:focus:border-light-primary transition-colors"
          placeholder="Your name"
        />
      </div>

      <div>
        <label for="email" class="font-mono text-xs text-primary light:text-light-primary uppercase tracking-wider block mb-2">
          EMAIL
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full bg-surface-container light:bg-light-surface-container border border-outline/30 light:border-light-outline/30 rounded px-4 py-3 font-body text-on-surface light:text-light-on-surface placeholder:text-on-surface-variant/40 light:placeholder:text-light-on-surface-variant/40 focus:outline-none focus:border-primary light:focus:border-light-primary transition-colors"
          placeholder="your@email.com"
        />
      </div>

      <div>
        <label for="message" class="font-mono text-xs text-primary light:text-light-primary uppercase tracking-wider block mb-2">
          MESSAGE
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="4"
          class="w-full bg-surface-container light:bg-light-surface-container border border-outline/30 light:border-light-outline/30 rounded px-4 py-3 font-body text-on-surface light:text-light-on-surface placeholder:text-on-surface-variant/40 light:placeholder:text-light-on-surface-variant/40 focus:outline-none focus:border-primary light:focus:border-light-primary transition-colors resize-none"
          placeholder="Your message..."
        ></textarea>
      </div>

      <div id="form-status" class="hidden font-mono text-sm"></div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full px-4 py-3 bg-primary light:bg-light-primary text-white dark:text-[#282828] font-mono text-sm uppercase tracking-wider rounded hover:opacity-90 transition-opacity flex items-center justify-center gap-2"
      >
        <span>SEND_MESSAGE</span>
        <span class="text-lg">&rarr;</span>
      </button>
    </form>
  </div>
</dialog>

<script>
  const modal = document.getElementById("contact-modal") as HTMLDialogElement;
  const closeBtn = document.getElementById("close-modal");
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const status = document.getElementById("form-status");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  let hasUnsavedChanges = false;

  form.addEventListener("input", () => {
    hasUnsavedChanges = true;
  });

  const confirmClose = () => {
    if (!hasUnsavedChanges || confirm("You have unsaved changes. Close anyway?")) {
      hasUnsavedChanges = false;
      return true;
    }
    return false;
  };

  modal.addEventListener("close", () => {
    document.body.style.overflow = "";
    const formData = new FormData(form);
    const wasSubmitted = formData.get("name") || formData.get("email") || formData.get("message");
    if (wasSubmitted && hasUnsavedChanges) {
      form.reset();
    }
    hasUnsavedChanges = false;
    status?.classList.add("hidden");
    status?.classList.remove("text-red-500", "text-green-500");
  });

  closeBtn?.addEventListener("click", () => {
    if (confirmClose()) {
      modal.close();
    }
  });

  modal.addEventListener("click", (e) => {
    if (e.target === modal && confirmClose()) {
      modal.close();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal.open) {
      if (confirmClose()) {
        modal.close();
      }
    }
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!status) return;

    submitBtn.disabled = true;
    submitBtn.textContent = "SENDING...";
    status.classList.add("hidden");

    const formData = new FormData(form);

    try {
      const response = await fetch("/api/contact", {
        method: "POST",
        body: formData,
      });

      const result = await response.json() as { success?: boolean; error?: string };

      if (result.success) {
        status.textContent = "✓ Message sent successfully!";
        status.classList.remove("hidden", "text-red-500");
        status.classList.add("text-green-500");
        setTimeout(() => {
          modal.close();
        }, 2000);
      } else {
        status.textContent = `✗ ${result.error || "Failed to send message"}`;
        status.classList.remove("hidden", "text-green-500");
        status.classList.add("text-red-500");
      }
    } catch (error) {
      status.textContent = "✗ Network error. Please try again.";
      status.classList.remove("hidden", "text-green-500");
      status.classList.add("text-red-500");
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span>SEND_MESSAGE</span><span class="text-lg">→</span>';
    }
  });
</script>

<style>
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
  }

  dialog[open] {
    animation: fade-in 0.2s ease-out;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  dialog[open] {
    display: flex !important;
  }

  @media (max-width: 640px) {
    dialog {
      margin: 1rem;
      max-width: calc(100% - 2rem);
    }
  }
</style>
