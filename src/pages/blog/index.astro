---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import Tag from '../../components/Tag.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<PageLayout title="Blog - Andrés Fernández">
  <section class="min-h-[calc(100vh-4rem)] bg-surface light:bg-light-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-24 pt-32 pb-24">
      <!-- Header Section -->
      <header class="mb-20">
        <h1 class="font-mono font-bold text-5xl md:text-7xl lg:text-8xl tracking-tighter text-on-surface light:text-light-on-surface mb-4">
          /BLOG
        </h1>
        <div class="flex flex-col md:flex-row md:items-center gap-4 mt-8">
          <p class="font-mono text-[0.6875rem] uppercase tracking-[0.2em] text-on-surface-variant light:text-light-on-surface-variant">
            LOCATION: TERMINAL_SESSION_01
          </p>
          <div class="hidden md:block h-px flex-grow bg-outline light:bg-light-outline opacity-30"></div>
          <p class="font-mono text-[0.6875rem] uppercase tracking-[0.2em] text-on-surface-variant light:text-light-on-surface-variant">
            STATUS: ONLINE_SYNCED
          </p>
        </div>
      </header>
      
      <!-- Blog List -->
      <section class="flex flex-col border-t border-outline/20 light:border-light-outline/20">
        {posts.map((post) => (
          <article class="group py-12 flex flex-col md:flex-row gap-6 md:gap-12 hover:bg-surface-container light:hover:bg-light-surface-container transition-colors border-b border-outline/20 light:border-light-outline/20 -mx-4 px-4 cursor-pointer">
            <div class="md:w-32 flex-shrink-0">
              <time class="font-mono text-[0.875rem] text-on-surface-variant light:text-light-on-surface-variant group-hover:text-primary light:group-hover:text-light-primary transition-colors">
                [{post.data.date.toISOString().split('T')[0]}]
              </time>
            </div>
            <div class="flex-grow">
              <h2 class="font-mono text-xl md:text-2xl font-bold mb-4">
                <a class="text-on-surface light:text-light-on-surface group-hover:text-primary light:group-hover:text-light-primary transition-colors flex items-center gap-2" href={`/blog/${post.id}`}>
                  <span class="opacity-0 group-hover:opacity-100 transition-opacity">&gt; </span>
                  {post.data.title}
                </a>
              </h2>
              <p class="text-on-surface-variant light:text-light-on-surface-variant max-w-2xl text-sm leading-relaxed mb-4">
                {post.data.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <Tag tag={tag} />
                ))}
              </div>
            </div>
          </article>
        ))}
        
        {posts.length === 0 && (
          <p class="font-mono text-sm text-on-surface-variant light:text-light-on-surface-variant py-12">No logs found. System idle...</p>
        )}
      </section>
      
      <!-- Load More -->
      <div class="mt-20 flex justify-center">
        <button class="bg-surface-container-high light:bg-light-surface-container-high text-on-surface light:text-light-on-surface px-8 py-4 font-mono text-[0.6875rem] uppercase tracking-widest hover:text-primary light:hover:text-light-primary transition-colors">
          LOAD_MORE_LOGS
        </button>
      </div>
    </div>
  </section>
</PageLayout>
